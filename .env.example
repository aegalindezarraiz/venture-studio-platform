# ════════════════════════════════════════════════════════════════════════════
#  AI Venture Studio OS — Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  En Railway: configura cada variable en Settings → Variables.
# ════════════════════════════════════════════════════════════════════════════

# ── Base de datos (Railway provee DATABASE_URL automáticamente) ──────────────
DATABASE_URL=postgresql://venture:venture@localhost:5432/venture_studio

# ── Redis (Railway provee REDIS_URL automáticamente) ────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Notion ────────────────────────────────────────────────────────────────────
# Obtén el token en: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# IDs de las 7 bases de datos del AI Venture Studio OS
NOTION_DB_STARTUPS=460c359a4f8849bd9c9a003e7520e7c0
NOTION_DB_OKRS=6575a70444b7404f87f1b1161b21748a
NOTION_DB_TASKS=1a166396f42a806ea9e1c2512f451f28
NOTION_DB_EXPERIMENTS=c00a6a2cde6243e9af6c4c636b5a7d14
NOTION_DB_BRIEFS=7956591d7f774ad69ac0bf8faeec02ac
NOTION_DB_AGENTS=cf83b9a4254a4140910e1bf50b3fd7d2
NOTION_DB_WEEKLY_REVIEWS=465c28a2359f449ba3865dd15df0a683

# ── Auth ──────────────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# En Railway: pon la URL de tu frontend, ej: https://mi-frontend.up.railway.app
CORS_ORIGINS=http://localhost:5173

# ── LLM / AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6

# ── Qdrant (memoria vectorial) ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=venture_memory

# ── Monitoreo (opcionales) ────────────────────────────────────────────────────
SENTRY_DSN=
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Agentes (URLs internas en Railway o Docker) ───────────────────────────────
AGENT_RUNTIME_URL=http://localhost:8001
SCALEOS_SUPERVISOR_URL=http://localhost:8002
SEO_OSINT_AGENT_URL=http://localhost:8003
GROWTH_INTELLIGENCE_URL=http://localhost:8004
